    {
      "parameters": {
        "jsCode": "const { content, fileName, category } = $('Validate Admin Key').first().json;\n\n// Decode base64 to plain text\nlet text;\ntry {\n  text = Buffer.from(content, 'base64').toString('utf-8');\n} catch (err) {\n  throw new Error('Failed to decode file content: ' + err.message);\n}\n\n// Clean up — remove BOM and excessive whitespace\ntext = text.replace(/^\\uFEFF/, '').trim();\n\n// Validate — don't process empty or tiny files\nif (!text || text.length < 50) {\n  throw new Error('File is empty or too short to process. Minimum 50 characters required. Got: ' + text.length);\n}\n\nreturn [{\n  json: {\n    text,\n    fileName,\n    category,\n    characterCount: text.length\n  }\n}];"
      },
      "id": "9906c1e4-4e07-4ecb-bf29-7f99eccfcfcd",
      "name": "Decode Base64 to Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
