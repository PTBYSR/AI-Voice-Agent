    },
    {
      "parameters": {
        "jsCode": "const { text, fileName, category } = $input.first().json;\n\nconst CHUNK_SIZE = 1500;\nconst CHUNK_OVERLAP = 200;\nconst uploadedAt = new Date().toISOString();\n\n// First try splitting on markdown headings\nlet sections = text.split(/(?=\\n#{1,3}\\s)/);\n\n// If no headings found, treat the whole text as one section\nif (sections.length === 1) {\n  sections = [text];\n}\n\nconst chunks = [];\nlet chunkIndex = 0;\n\nfor (const section of sections) {\n  const trimmed = section.trim();\n  if (trimmed.length === 0) continue;\n\n  // Try to extract a heading from this section\n  const headingMatch = trimmed.match(/^#{1,3}\\s+(.+)/);\n  const sectionTitle = headingMatch ? headingMatch[1].trim() : 'General';\n\n  // If section fits in one chunk, keep it as-is\n  if (trimmed.length <= CHUNK_SIZE) {\n    chunks.push({\n      content: trimmed,\n      metadata: {\n        source: fileName,\n        category: category,\n        section: sectionTitle,\n        chunk_index: chunkIndex,\n        uploaded_at: uploadedAt\n      }\n    });\n    chunkIndex++;\n    continue;\n  }\n\n  // Section is too large — split by paragraphs with overlap\n  const paragraphs = trimmed.split(/\\n\\n+/);\n  let currentChunk = '';\n\n  for (const para of paragraphs) {\n    const testLength = currentChunk\n      ? (currentChunk + '\\n\\n' + para).length\n      : para.length;\n\n    if (testLength > CHUNK_SIZE && currentChunk.length > 0) {\n      // Save current chunk\n      chunks.push({\n        content: currentChunk.trim(),\n        metadata: {\n          source: fileName,\n          category: category,\n          section: sectionTitle,\n          chunk_index: chunkIndex,\n          uploaded_at: uploadedAt\n        }\n      });\n      chunkIndex++;\n\n      // Start new chunk with overlap from the end of previous\n      const overlap = currentChunk.slice(-CHUNK_OVERLAP);\n      currentChunk = overlap + '\\n\\n' + para;\n    } else {\n      currentChunk = currentChunk\n        ? currentChunk + '\\n\\n' + para\n        : para;\n    }\n  }\n\n  // Save the last chunk from this section\n  if (currentChunk.trim().length > 0) {\n    chunks.push({\n      content: currentChunk.trim(),\n      metadata: {\n        source: fileName,\n        category: category,\n        section: sectionTitle,\n        chunk_index: chunkIndex,\n        uploaded_at: uploadedAt\n      }\n    });\n    chunkIndex++;\n  }\n}\n\n// Safety check\nif (chunks.length === 0) {\n  throw new Error('Chunking produced zero chunks. Check the input text.');\n}\n\n// Return each chunk as a separate item\nreturn chunks.map(c => ({ json: c }));"
      },
