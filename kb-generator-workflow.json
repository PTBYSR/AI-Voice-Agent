        "jsCode": "const jinaResponse = $input.first().json;\nconst authData = $('Validate Admin Key').first().json;\n\nconst text = jinaResponse.data || jinaResponse.body || (typeof jinaResponse === 'string' ? jinaResponse : JSON.stringify(jinaResponse));\n\nconst cleanText = (typeof text === 'string' ? text : String(text)).trim();\n\nif (!cleanText || cleanText.length < 50) {\n  throw new Error('Jina returned empty or insufficient content from the URL. The page might be behind a login or block scrapers.');\n}\n\n// Extract a filename from the URL without using URL constructor\nconst url = authData.url || 'unknown';\nconst fileName = url\n  .replace(/^https?:\\/\\//, '')\n  .replace(/[^a-zA-Z0-9.-]/g, '_')\n  .slice(0, 60) + '.md';\n\nreturn [{\n  json: {\n    text: cleanText,\n    fileName,\n    category: authData.category,\n    characterCount: cleanText.length\n  }\n}];"
